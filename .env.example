# ─────────────────────────────────────────────────────────────
# MCP Marketing Agent — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Adjust ────────────────────────────────────────────────────
# Your Adjust API token. Found in: Adjust Dashboard → Account Settings → API
ADJUST_API_TOKEN=your_adjust_api_token_here

# ── Google Ads (Phase 2) ──────────────────────────────────────
# GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
# GOOGLE_ADS_CLIENT_ID=your_oauth_client_id_here
# GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret_here
# GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
# GOOGLE_ADS_CUSTOMER_ID=your_customer_id_here
